//@version=6
strategy("Close Above 20 EMA Strategy", overlay=true, pyramiding=0, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.0)

emaLength = input.int(20, "EMA Length", minval=1)
stopLossPct = input.float(3.0, "Stop Loss %", minval=0.1, step=0.1)
targetProfitPct = input.float(15.0, "Target Profit %", minval=0.1, step=0.1)

ema20 = ta.ema(close, emaLength)
longCondition = close > ema20 and strategy.position_size == 0

if longCondition
    strategy.entry("Long", strategy.long)

if strategy.position_size > 0
    stopPrice = strategy.position_avg_price * (1 - stopLossPct / 100)
    targetPrice = strategy.position_avg_price * (1 + targetProfitPct / 100)
    strategy.exit("Long Exit", from_entry="Long", stop=stopPrice, limit=targetPrice)

plot(ema20, title="EMA 20", color=color.orange, linewidth=2)
